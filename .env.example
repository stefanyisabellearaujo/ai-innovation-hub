# =============================================================================
# AI Innovation Hub — Frontend Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# URL do backend usada pelo nginx para proxy das requisições /api
# - Local com docker-compose: http://host.docker.internal:8000 (padrão)
# - Produção: http://<ip-ou-dominio-do-backend>:8000
BACKEND_URL=http://host.docker.internal:8000

# URL base da API para desenvolvimento local (usado pelo Vite proxy em `npm run dev`)
VITE_API_URL=http://localhost:8000
